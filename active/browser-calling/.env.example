# Twilio Core
ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
API_KEY_SECRET=your_api_key_secret
TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Security
TOKEN_SECRET=your_32_char_secret

# Phone Numbers (E.164)
AIRCALL_NUMBER=+64xxxxxxxxx
TWILIO_NUMBER=+64xxxxxxxxx

# GAS Webhook
GAS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# Twilio Function URLs (set after first deploy)
WHISPER_HANDLER_URL=https://browser-calling-XXXX.twil.io/whisper-handler
TRANSCRIPT_HANDLER_URL=https://browser-calling-XXXX.twil.io/transcript-handler

# Twilio Sync
SYNC_SERVICE_SID=ISxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
